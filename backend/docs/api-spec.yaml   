/masters/customers:
  post:
    summary: Create a new customer
    tags: [Masters]
    security:
      - bearerAuth: []
    requestBody:
      required: true
      content:
        application/json:
          schema:
            type: object
            required: [name, gstin, state, email]
            properties:
              name:
                type: string
                example: "Reliance Industries"
              gstin:
                type: string
                pattern: "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[0-9A-Z]{1}Z[0-9A-Z]{1}$"
                example: "27AABCR1718E1ZM"
              state:
                type: string
                example: "MH"
              email:
                type: string
    responses:
      201:
        description: Customer created
      400:
        description: Validation failed
      401:
        description: Unauthorized