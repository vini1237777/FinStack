{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "backend/src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["backend/src/**/*"],
  "exclude": ["dist"]
}
